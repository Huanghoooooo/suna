{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "task": "deny",
  },
  "autoupdate": false,
  "disabled_providers": ["opencode"],
  "default_agent": "general",
  // Shared system prompt base — always injected into every agent session.
  // Agent-specific persona/loop/rules live in ./agents/<name>.md.
  "instructions": ["./kortix-system.md"],
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "explore": { "disable": true },
  },
  // ──────────────────────────────────────────────────────────────────────────
  // Provider registry — HARDCODED. End users cannot add providers via the UI.
  // To add/change a provider: edit this file + set the matching API key in
  // `apps/api/.env`, then redeploy. See docs/custom-providers.md.
  // ──────────────────────────────────────────────────────────────────────────
  "provider": {
    // Kortix-hosted router (default). Uses KORTIX_TOKEN from the sandbox env.
    "kortix": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["KORTIX_TOKEN", "KORTIX_API_URL"],
      "options": {
        "baseURL": "{env:KORTIX_API_URL}/v1/router",
        "apiKey": "{env:KORTIX_TOKEN}",
      },
      "models": {
        "minimax-m27": {
          "name": "MiniMax M2.7",
          "id": "minimax/minimax-m2.7",
          "family": "kortix",
          "cost": { "input": 0.3, "output": 1.2 },
          "limit": { "context": 204800, "output": 131072 },
        },
        "glm-turbo": {
          "name": "GLM-5 Turbo",
          "id": "z-ai/glm-5-turbo",
          "family": "kortix",
          "cost": { "input": 1.2, "output": 4.0 },
          "limit": { "context": 202752, "output": 131072 },
        },
        "kimi": {
          "name": "Kimi K2.5",
          "id": "moonshotai/kimi-k2.5",
          "family": "kortix",
          "cost": { "input": 0.45, "output": 2.2 },
          "limit": { "context": 262144, "output": 65535 },
        },
        "minimax": {
          "name": "MiniMax M2.5",
          "id": "minimax/minimax-m2.5",
          "family": "kortix",
          "cost": { "input": 0.2, "output": 1.17 },
          "limit": { "context": 196608, "output": 65536 },
        },
      },
    },
    // GLM 官方（智谱）— requires BIGMODEL_API_KEY.
    "bigmodel": {
      "name": "GLM官方",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "{env:BIGMODEL_API_KEY}",
      },
      "models": {
        "glm-5-1": {
          "name": "GLM-5.1",
          "id": "glm-5.1",
        },
      },
    },
    // Claude 中转（apipool.dev）— requires CLAUDE_API_KEY.
    "claude": {
      "name": "Claude (apipool)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.apipool.dev/v1",
        "apiKey": "{env:CLAUDE_API_KEY}",
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7",
          "id": "claude-opus-4-7",
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "id": "claude-sonnet-4-6",
        },
      },
    },
    // ── Examples (OpenAI-compatible) — uncomment + set API key to enable ──
    //
    // "openai": {
    //   "name": "OpenAI",
    //   "npm": "@ai-sdk/openai-compatible",
    //   "options": {
    //     "baseURL": "https://api.openai.com/v1",
    //     "apiKey": "{env:OPENAI_API_KEY}",
    //   },
    //   "models": {
    //     "gpt-4o": { "name": "GPT-4o", "id": "gpt-4o" },
    //     "gpt-4o-mini": { "name": "GPT-4o mini", "id": "gpt-4o-mini" },
    //   },
    // },
    //
    // "deepseek": {
    //   "name": "DeepSeek",
    //   "npm": "@ai-sdk/openai-compatible",
    //   "options": {
    //     "baseURL": "https://api.deepseek.com/v1",
    //     "apiKey": "{env:DEEPSEEK_API_KEY}",
    //   },
    //   "models": {
    //     "deepseek-chat": { "name": "DeepSeek Chat", "id": "deepseek-chat" },
    //     "deepseek-reasoner": { "name": "DeepSeek Reasoner", "id": "deepseek-reasoner" },
    //   },
    // },
    //
    // "moonshot": {
    //   "name": "Moonshot",
    //   "npm": "@ai-sdk/openai-compatible",
    //   "options": {
    //     "baseURL": "https://api.moonshot.cn/v1",
    //     "apiKey": "{env:MOONSHOT_API_KEY}",
    //   },
    //   "models": {
    //     "kimi-k2": { "name": "Kimi K2", "id": "kimi-k2-0711-preview" },
    //   },
    // },
  },
  "plugin": [
    "./plugin/kortix-system/kortix-system.ts",
    "./plugin/opencode-caveman-plugin/opencode-caveman-plugin.ts",
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "enabled": true,
    },
  },
}
