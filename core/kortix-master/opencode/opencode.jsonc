{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "task": "deny",
  },
  "autoupdate": false,
  "disabled_providers": ["opencode"],
  "default_agent": "general",
  // Shared system prompt base — always injected into every agent session.
  // Agent-specific persona/loop/rules live in ./agents/<name>.md.
  "instructions": ["./kortix-system.md"],
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "explore": { "disable": true },
  },
  "provider": {
    "kortix": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["KORTIX_TOKEN", "KORTIX_API_URL"],
      "options": {
        "baseURL": "{env:KORTIX_API_URL}/v1/router",
        "apiKey": "{env:KORTIX_TOKEN}",
      },
      "models": {
        "minimax-m27": {
          "name": "MiniMax M2.7",
          "id": "minimax/minimax-m2.7",
          "family": "kortix",
          "cost": { "input": 0.3, "output": 1.2 },
          "limit": { "context": 204800, "output": 131072 },
        },
        "glm-turbo": {
          "name": "GLM-5 Turbo",
          "id": "z-ai/glm-5-turbo",
          "family": "kortix",
          "cost": { "input": 1.2, "output": 4.0 },
          "limit": { "context": 202752, "output": 131072 },
        },
        "kimi": {
          "name": "Kimi K2.5",
          "id": "moonshotai/kimi-k2.5",
          "family": "kortix",
          "cost": { "input": 0.45, "output": 2.2 },
          "limit": { "context": 262144, "output": 65535 },
        },
        "minimax": {
          "name": "MiniMax M2.5",
          "id": "minimax/minimax-m2.5",
          "family": "kortix",
          "cost": { "input": 0.2, "output": 1.17 },
          "limit": { "context": 196608, "output": 65536 },
        },
      },
    },
    "11": {
      "name": "111",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://",
        "apiKey": "{env:PROVIDER_11_API_KEY}",
      },
      "models": {
        "111111": {
          "name": "11111",
          "id": "111111",
        },
      },
    },
    "bigmodel": {
      "name": "GLM官方",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "{env:BIGMODEL_API_KEY}",
      },
      "models": {
        "glm-5-1": {
          "name": "glm-5.1",
          "id": "glm-5.1",
        },
      },
    },
    "zhipu-glm51": {
      "name": "智谱 GLM-5.1",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4/",
        "apiKey": "{env:BIGMODEL_API_KEY}",
      },
      "models": {
        "glm-5-1": {
          "name": "glm-5.1",
          "id": "glm-5.1",
        },
      },
    },
  },
  "plugin": [
    "./plugin/kortix-system/kortix-system.ts",
    "./plugin/opencode-caveman-plugin/opencode-caveman-plugin.ts",
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "enabled": true,
    },
  },
}
