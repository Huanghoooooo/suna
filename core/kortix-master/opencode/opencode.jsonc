{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "task": "deny",
  },
  "autoupdate": false,
  "disabled_providers": ["opencode", "openrouter"],
  "model": "apipool/claude-opus-4-7",
  "small_model": "apipool/claude-opus-4-7",
  "default_agent": "general",
  // Shared system prompt base — always injected into every agent session.
  // Agent-specific persona/loop/rules live in ./agents/<name>.md.
  "instructions": ["./kortix-system.md"],
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "explore": { "disable": true },
  },
  // ──────────────────────────────────────────────────────────────────────────
  // Provider registry — HARDCODED. End users cannot add providers via the UI.
  // To add/change a provider: edit this file + set the matching API key in
  // `apps/api/.env`, then redeploy. See docs/custom-providers.md.
  // ──────────────────────────────────────────────────────────────────────────
  "provider": {
    // API Pool (default) — requires OPENROUTER_API_KEY.
    "apipool": {
      "name": "Wu tong",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.apipool.dev/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}",
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7",
          "id": "claude-opus-4-7",
        }
      },
    },
    // GLM 官方（智谱）— requires BIGMODEL_API_KEY.
    "bigmodel": {
      "name": "GLM官方",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "{env:BIGMODEL_API_KEY}",
      },
      "models": {
        "glm-5-1": {
          "name": "GLM-5.1",
          "id": "glm-5.1",
        },
      },
    },
    // ── Examples (OpenAI-compatible) — uncomment + set API key to enable ──
    //
    // "openai": {
    //   "name": "OpenAI",
    //   "npm": "@ai-sdk/openai-compatible",
    //   "options": {
    //     "baseURL": "https://api.openai.com/v1",
    //     "apiKey": "{env:OPENAI_API_KEY}",
    //   },
    //   "models": {
    //     "gpt-4o": { "name": "GPT-4o", "id": "gpt-4o" },
    //     "gpt-4o-mini": { "name": "GPT-4o mini", "id": "gpt-4o-mini" },
    //   },
    // },
    //
    // "deepseek": {
    //   "name": "DeepSeek",
    //   "npm": "@ai-sdk/openai-compatible",
    //   "options": {
    //     "baseURL": "https://api.deepseek.com/v1",
    //     "apiKey": "{env:DEEPSEEK_API_KEY}",
    //   },
    //   "models": {
    //     "deepseek-chat": { "name": "DeepSeek Chat", "id": "deepseek-chat" },
    //     "deepseek-reasoner": { "name": "DeepSeek Reasoner", "id": "deepseek-reasoner" },
    //   },
    // },
    //
    // "moonshot": {
    //   "name": "Moonshot",
    //   "npm": "@ai-sdk/openai-compatible",
    //   "options": {
    //     "baseURL": "https://api.moonshot.cn/v1",
    //     "apiKey": "{env:MOONSHOT_API_KEY}",
    //   },
    //   "models": {
    //     "kimi-k2": { "name": "Kimi K2", "id": "kimi-k2-0711-preview" },
    //   },
    // },
  },
  "plugin": [
    "./plugin/kortix-system/kortix-system.ts",
    "./plugin/opencode-caveman-plugin/opencode-caveman-plugin.ts",
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "enabled": true,
    },
  },
}
