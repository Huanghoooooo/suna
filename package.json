{
  "name": "kortix",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev-local.sh",
    "single:dev": "bash scripts/single/dev.sh",
    "single:deploy": "bash scripts/single/deploy.sh",
    "single:stop": "bash scripts/single/stop.sh",
    "single:api": "pnpm --filter kortix-single-api dev",
    "single:web": "pnpm --filter kortix-single-web dev",
    "dev:prod": "bash scripts/dev-prod.sh",
    "dev:web": "pnpm --filter Kortix-Computer-Frontend dev",
    "dev:frontend": "pnpm --filter Kortix-Computer-Frontend dev",
    "dev:mobile": "pnpm --filter ./apps/mobile dev",
    "dev:api": "KORTIX_DEV_MODE=1 pnpm --filter kortix-api dev",
    "dev:core": "bash scripts/dev-sandbox.sh",
    "dev:core:build": "bash scripts/dev-sandbox.sh --build",
    "dev:sandbox": "bash scripts/dev-sandbox.sh",
    "dev:sandbox:build": "bash scripts/dev-sandbox.sh --build",
    "build": "pnpm -r run build",
    "nuke": "bash scripts/nuke-local.sh",
    "nuke:start": "bash scripts/nuke-local.sh --start",
    "start": "bash scripts/start-local.sh",
    "compose:up": "docker compose -f scripts/compose/docker-compose.yml --profile all up -d --build",
    "compose:backend": "docker compose -f scripts/compose/docker-compose.yml --profile backend up -d --build",
    "compose:frontend": "docker compose -f scripts/compose/docker-compose.yml --profile frontend up -d --build",
    "prod:sandbox": "docker compose -f core/docker/docker-compose.yml up -d",
    "prod:sandbox:build": "docker compose -f core/docker/docker-compose.yml up -d --build",
    "deploy:frontend": "docker compose -f scripts/compose/docker-compose.yml --profile frontend-only up -d --build",
    "deploy:api": "pnpm --filter kortix-api start",
    "deploy:sandbox": "docker compose -f core/docker/docker-compose.yml up -d",
    "deploy:sandbox:build": "docker compose -f core/docker/docker-compose.yml up -d --build",
    "stripe:listen": "stripe listen --forward-to http://localhost:8008/v1/billing/webhooks/stripe",
    "hooks:install": "uvx pre-commit install",
    "security:secrets:check": "uvx pre-commit run detect-secrets --all-files"
  },
  "devDependencies": {
    "agent-tunnel": "workspace:@kortix/agent-tunnel@*",
    "supabase": "^2.89.1"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.28",
      "@types/react-dom": "^18.3.7"
    }
  },
  "packageManager": "pnpm@8.15.8+sha512.d1a029e1a447ad90bc96cd58b0fad486d2993d531856396f7babf2d83eb1823bb83c5a3d0fc18f675b2d10321d49eb161fece36fe8134aa5823ecd215feed392"
}
