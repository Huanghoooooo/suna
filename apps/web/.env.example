# Required runtime frontend env
NEXT_PUBLIC_ENV_MODE=local
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_BACKEND_URL=http://localhost:8008/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── LAN access ──────────────────────────────────────────────────────────────
# To access from other machines on the LAN, replace localhost/127.0.0.1 with
# your server's LAN IP and run the nginx proxy (scripts/nginx/start-nginx.sh):
#   NEXT_PUBLIC_SUPABASE_URL=http://<LAN_IP>:54321
#   NEXT_PUBLIC_BACKEND_URL=http://<LAN_IP>/v1

# Better Stack observability [OPTIONAL]
# Error tracking — Sentry-compatible DSN, tunneled via /monitoring to bypass ad-blockers
# NEXT_PUBLIC_SENTRY_DSN=
# Structured logging — @logtail/next source token + ingesting host
# NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=
# NEXT_PUBLIC_BETTER_STACK_INGESTING_URL=
