SINGLE_API_HOST=0.0.0.0
SINGLE_API_PORT=18008
SINGLE_PUBLIC_API_URL=http://localhost:18008
SINGLE_WEB_URL=http://localhost:13000

SINGLE_SANDBOX_CONTAINER=kortix-single-sandbox
SINGLE_SANDBOX_BASE_URL=http://127.0.0.1:14000
SINGLE_SANDBOX_TOKEN=kortix_single_dev_token_change_me
SINGLE_DATA_DIR=.single-data
SINGLE_COMPOSE_FILE=core/docker/docker-compose.yml

# Use a public/LAN URL here if the sandbox must call back into the API.
KORTIX_API_URL=http://host.docker.internal:18008

# Default OpenCode model used by single mode.
SINGLE_MODEL=apipool/claude-opus-4-7

# Optional model/tool keys forwarded into the sandbox.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
BIGMODEL_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CONTEXT7_API_KEY=
